PORT=3001
# Devnet (matches the business plan). Use wss://s.altnet.rippletest.net:51233 for Testnet.
XRPL_NODE=wss://s.devnet.rippletest.net:51233
DB_PATH=./greentrace.db

# Self-issued test IOU used for escrow proceeds (issuer is the local "issuer" wallet at runtime)
RLUSD_CURRENCY=524C555344000000000000000000000000000000

# Real Ripple USD issuer on XRPL Testnet (top up wallets at https://tryrlusd.com)
RLUSD_ISSUER=rQhWct2fv4Vc4KRjRgMrxa8xPN9Zx9iLKV

# Agent verification loop interval (ms)
AGENT_INTERVAL_MS=30000
# Grace delay before the first AUTOMATIC cycle (ms), so the live "Run Now" breach flip is
# demo-controllable. Set 0 to start auto-cycling immediately.
AGENT_START_DELAY_MS=120000
